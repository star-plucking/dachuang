# Optional image generation settings.
# Copy this file to .env and fill the values locally. Do not commit real keys.

# OpenAI GPT Image family.
# Official docs currently list GPT Image models such as gpt-image-1.5,
# gpt-image-1, and gpt-image-1-mini. If your account supports another model
# such as gpt-image-2, set it here manually.
OPENAI_API_KEY=
DACHUANG_OPENAI_IMAGE_MODEL=gpt-image-1.5

# Nano Banana 2 or a third-party compatible image endpoint.
# The script sends JSON with model, prompt, size, quality, and n.
DACHUANG_NANO_BANANA2_API_URL=
DACHUANG_NANO_BANANA2_API_KEY=
DACHUANG_NANO_BANANA2_MODEL=nano-banana-2

